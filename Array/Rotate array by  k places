class Solution {

    static void reverse(int[] arr, int start, int end) {
        while(start < end) {
            int temp = arr[start];
            arr[start] = arr[end];
            arr[end] = temp;

            start++;
            end--;
        }
    }
    
    public void rotate(int[] arr, int k) {

        int n=arr.length;                  
        k=k%n;                     // LEFT ROTATION : Elements move toward the left, and the first elements wrap to the end.
        reverse(arr,0,k-1);
        reverse(arr,k,n-1);
        reverse(arr,0,n-1);
        
        
    }
}


// RIGHT ROTATION : Elements move toward the right, and the last elements wrap to the beginning.

    static void rotate(int[] arr, int k) {
        int n = arr.length;
        k = k % n;
        reverse(arr, 0, n - 1);
        reverse(arr, 0, k - 1);
        reverse(arr, k, n - 1);
    }



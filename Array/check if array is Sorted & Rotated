class Solution {
    public boolean check(int[] arr) {
        int count=0;
        for(int i=0;i<arr.length;i++){
            if(arr[i]>arr[(i+1) % arr.length]){ // doing modulus arr.length compares last vs first(so,array is treated like a circle)
                count++; //count stores how many times the sorted order breaks.
            }
        }
        return count<=1; // breaks ≤ 1  → valid sorted rotated array if breaks > 1  → invalid
        
    }
}
